{
  "name": "jnguyenco-crm",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:types": "supabase gen types typescript --local > lib/supabase/database.types.ts",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@react-pdf/renderer": "^3.4.0",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.0",
    "@types/nodemailer": "^8.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "googleapis": "^140.0.0",
    "lucide-react": "^0.400.0",
    "next": "14.2.5",
    "nodemailer": "^8.0.11",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.jnguyen.crm",
    "productName": "JNguyen Co. CRM",
    "copyright": "JNguyen Co.",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/main.js"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "server",
        "filter": ["**/*"]
      },
      {
        "from": ".next/static",
        "to": "server/.next/static",
        "filter": ["**/*"]
      },
      {
        "from": "public",
        "to": "server/public",
        "filter": ["**/*"]
      },
      {
        "from": ".env.production",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JNguyen Co. CRM"
    }
  }
}
