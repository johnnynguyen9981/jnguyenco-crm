# ─────────────────────────────────────────────────────────────────────────────
# JNguyen Co. CRM — Environment Variables
# Copy to .env.local and fill in your values. NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key: NEVER expose to browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add Authorized redirect URI: https://your-app.vercel.app/api/auth/callback
# 3. Enable: Gmail API + Google Calendar API
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Change GOOGLE_REDIRECT_URI to your Vercel URL in production

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Change to https://crm.jnguyen.co in production

# ── Business ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_NAME=JNguyen Co.
NEXT_PUBLIC_BUSINESS_EMAIL=johnny.nguyen@jnguyen.co
NEXT_PUBLIC_BUSINESS_PHONE=+61 XXX XXX XXX
NEXT_PUBLIC_BUSINESS_ABN=XX XXX XXX XXX
